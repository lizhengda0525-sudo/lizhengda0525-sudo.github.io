[
{{- $pages := (where site.RegularPages "Section" "posts").ByDate.Reverse -}}
{{- range $index, $page := $pages }}{{ if $index }},{{ end }}
  {
    "title": {{ $page.Title | jsonify }},
    "permalink": {{ $page.RelPermalink | jsonify }},
    "date": {{ $page.Date.Format "2006-01-02" | jsonify }},
    "summary": {{ with $page.Description }}{{ . | jsonify }}{{ else }}{{ $page.Summary | plainify | htmlUnescape | jsonify }}{{ end }},
    "content": {{ $page.Plain | jsonify }},
    "categories": {{ $page.Params.categories | default (slice) | jsonify }},
    "tags": {{ $page.Params.tags | default (slice) | jsonify }}
  }
{{- end }}
]
